# LLM Configuration
LLM_MODEL=gpt-4-turbo
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database Configuration
DATABASE_TYPE=sqlite # Options: sqlite, postgresql, mysql
DATABASE_URL=sqlite:///./data/performance.db # For SQLite, use sqlite:///./data/performance.db. For PostgreSQL/MySQL, use the appropriate connection string.

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/performance.log

# Monitoring
MONITOR_INTERVAL=30
CPU_THRESHOLD=80
MEMORY_THRESHOLD=85

# CrewAI Settings
CREW_VERBOSE=true
CREW_EXECUTOR=sequential
